        <mxCell id="method4" value="数值仿真" style="rounded=1;whiteSpace=wrap;html=1;arcSize=20;fillColor=#FEF3C7;strokeColor=#F59E0B;strokeWidth=1.5;fontSize=15;fontStyle=1;fontFamily=Microsoft YaHei;fontColor=#0F172A;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="580" y="176" width="160" height="42" as="geometry" />
        </mxCell>
        <mxCell id="method5" value="实验验证" style="rounded=1;whiteSpace=wrap;html=1;arcSize=20;fillColor=#FCE7F3;strokeColor=#F472B6;strokeWidth=1.5;fontSize=15;fontStyle=1;fontFamily=Microsoft YaHei;fontColor=#0F172A;align=center;verticalAlign=middle;" parent="1" vertex="1">
