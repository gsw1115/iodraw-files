        </mxCell>
        <mxCell id="5HqSUERzATd3i8zwnFVZ-43" value="&lt;div style=&quot;line-height:1.45;&quot;&gt;&lt;b&gt;High-frequency communication across the full chain:&lt;/b&gt; Integrate user engagement into the operational loop, ensuring both contractual delivery and continuous day-to-day support.&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fontFamily=Times New Roman;fontSize=16;fontColor=#5E6878;spacing=0;" vertex="1" parent="1">
          <mxGeometry x="651" y="441" width="382" height="125" as="geometry" />
        </mxCell>
