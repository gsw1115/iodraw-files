        <mxCell id="5HqSUERzATd3i8zwnFVZ-49" value="&lt;div style=&quot;line-height:1.45;&quot;&gt;&lt;b&gt;Seamless execution of directives:&lt;/b&gt; Promote standardized, orderly, and efficient internal operations, ensuring that tasks assigned by institute leadership are completed to a high standard.&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fontFamily=Times New Roman;fontSize=16;fontColor=#5E6878;spacing=0;" vertex="1" parent="1">
