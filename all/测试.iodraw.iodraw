        <mxCell id="cTS2Bc4Euz190X_VzW5h-4" value="&lt;b&gt;Engineering Constraints:&lt;/b&gt; Long range + limited communication → waypoints are not downloaded; only heading commands are downloaded." style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;strokeColor=#333333;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;fillColor=#E6E6E6;" vertex="1" parent="1">
          <mxGeometry x="150" y="825" width="430" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cTS2Bc4Euz190X_VzW5h-5" value="&lt;b&gt;Stability Strategy:&lt;/b&gt; Waypoints are fixed within each planning cycle to avoid instability and communication burden caused by frequent global re-planning." style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;strokeColor=#333333;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;fillColor=#E6E6E6;" vertex="1" parent="1">
          <mxGeometry x="590" y="825" width="450" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cTS2Bc4Euz190X_VzW5h-6" value="&lt;b&gt;Robustness Source:&lt;/b&gt; Periodic receding-horizon update + surfacing-event correction → simultaneously handles prediction and navigation errors." style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;strokeColor=#333333;strokeWidth=2;fontFamily=Times New Roman;fontSize=16;fillColor=#E6E6E6;" vertex="1" parent="1">
