        </mxCell>
        <mxCell id="5HqSUERzATd3i8zwnFVZ-47" value="&lt;div style=&quot;line-height:1.45;&quot;&gt;&lt;b&gt;Detailed support for routine operations:&lt;/b&gt; Assist the department head in coordinating internal affairs, strengthen cross-role collaboration, and improve administrative efficiency.&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fontFamily=Times New Roman;fontSize=16;fontColor=#5E6878;spacing=0;" vertex="1" parent="1">
