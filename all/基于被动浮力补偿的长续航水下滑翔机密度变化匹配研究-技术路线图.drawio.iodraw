        <mxCell id="s1bg" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#F8FAFC;strokeColor=#94A3B8;strokeWidth=1.5;" parent="1" vertex="1">
          <mxGeometry x="40" y="250" width="500" height="980" as="geometry" />
        </mxCell>
        <mxCell id="s1h" value="阶段 1  问题识别与目标定义" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#475569;strokeColor=#334155;strokeWidth=1.5;fontSize=18;fontStyle=1;fontFamily=Microsoft YaHei;fontColor=#FFFFFF;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="70" y="278" width="440" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s1t" value="1. 识别长航程滑翔机能耗瓶颈&#xa;2. 分析密度跃层与壳体压缩耦合作用&#xa;3. 明确研究目标、评价指标与约束条件&#xa;4. 聚焦浅海 0-300 m 密度变化匹配问题" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=1.2;fontSize=16;fontFamily=Microsoft YaHei;fontColor=#1E293B;align=left;spacingLeft=16;spacingTop=16;" parent="1" vertex="1">
          <mxGeometry x="70" y="370" width="440" height="430" as="geometry" />
        </mxCell>
        <mxCell id="s1o" value="阶段输出&#xa;问题定义 + 评价指标体系" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FEF3C7;strokeColor=#F59E0B;strokeWidth=1.5;fontSize=17;fontStyle=1;fontFamily=Microsoft YaHei;fontColor=#92400E;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="70" y="1060" width="440" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s2bg" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#EFF6FF;strokeColor=#60A5FA;strokeWidth=1.5;" parent="1" vertex="1">
          <mxGeometry x="620" y="250" width="500" height="980" as="geometry" />
