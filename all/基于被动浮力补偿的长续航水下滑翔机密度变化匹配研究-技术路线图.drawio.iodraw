        <mxCell id="method3" value="参数优化" style="rounded=1;whiteSpace=wrap;html=1;arcSize=20;fillColor=#DCFCE7;strokeColor=#4ADE80;strokeWidth=1.5;fontSize=15;fontStyle=1;fontFamily=Microsoft YaHei;fontColor=#0F172A;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="400" y="176" width="160" height="42" as="geometry" />
