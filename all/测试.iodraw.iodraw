        <mxCell id="cTS2Bc4Euz190X_VzW5h-35" value="&lt;b&gt;1) Shore-based Equivalent&lt;br&gt;Modeling and Path Planning&lt;br&gt;Module&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontFamily=Times New Roman;fontSize=18;" vertex="1" parent="1">
