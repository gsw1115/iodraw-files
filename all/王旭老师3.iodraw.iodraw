        </mxCell>
        <mxCell id="5HqSUERzATd3i8zwnFVZ-45" value="&lt;div style=&quot;line-height:1.45;&quot;&gt;&lt;b&gt;Deepening strategic trust:&lt;/b&gt; Provide consistently high-quality technical support to consolidate the basis for cooperation and build stable, long-term partnerships.&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fontFamily=Times New Roman;fontSize=16;fontColor=#5E6878;spacing=0;" vertex="1" parent="1">
          <mxGeometry x="651" y="589" width="382" height="130" as="geometry" />
