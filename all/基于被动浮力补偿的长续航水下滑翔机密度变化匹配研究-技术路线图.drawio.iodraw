        </mxCell>
        <mxCell id="s6o" value="阶段输出&#xa;节能效果与可靠性验证" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFE4E6;strokeColor=#FB7185;strokeWidth=1.5;fontSize=17;fontStyle=1;fontFamily=Microsoft YaHei;fontColor=#9F1239;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="2970" y="1060" width="440" height="110" as="geometry" />
        </mxCell>
        <mxCell id="result" value="预期研究成果：主被动混合浮力调节系统方案｜综合动力学与能耗模型｜优化参数与协调控制策略｜样机与海试验证数据｜SCI 论文与硕士学位论文" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=1.8;fontSize=18;fontStyle=1;fontFamily=Microsoft YaHei;fontColor=#0F172A;align=center;verticalAlign=middle;" parent="1" vertex="1">
