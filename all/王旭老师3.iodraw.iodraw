        <mxCell id="5HqSUERzATd3i8zwnFVZ-35" value="Full-Lifecycle Project Management" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=middle;fontFamily=Times New Roman;fontSize=18;fontStyle=1;fontColor=#10182B;spacing=0;" vertex="1" parent="1">
