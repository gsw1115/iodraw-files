  <diagram id="tech-roadmap-001" name="技术路线图">
    <mxGraphModel dx="1426" dy="783" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3600" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="基于被动浮力补偿的长续航水下滑翔机密度变化匹配研究技术路线图" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontFamily=Microsoft YaHei;fontColor=#0F172A;" parent="1" vertex="1">
          <mxGeometry x="40" y="24" width="2000" height="42" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="总体目标：针对浅海密度跃层引发的额外能耗问题，构建主被动混合浮力调节方案，提升长续航水下滑翔机的全潜深环境适应性、节能效果与续航能力。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=1.5;fontSize=17;fontFamily=Microsoft YaHei;fontColor=#334155;spacing=16;" parent="1" vertex="1">
          <mxGeometry x="40" y="78" width="3520" height="78" as="geometry" />
        </mxCell>
        <mxCell id="method1" value="文献分析" style="rounded=1;whiteSpace=wrap;html=1;arcSize=20;fillColor=#E0F2FE;strokeColor=#38BDF8;strokeWidth=1.5;fontSize=15;fontStyle=1;fontFamily=Microsoft YaHei;fontColor=#0F172A;align=center;verticalAlign=middle;" parent="1" vertex="1">
